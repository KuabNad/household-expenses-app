rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isMember(householdId) {
      return signedIn()
        && exists(/databases/$(database)/documents/households/$(householdId))
        && get(/databases/$(database)/documents/households/$(householdId))
          .data.memberIds.hasAny([request.auth.uid]);
    }

    function isMemberAfter(householdId) {
      return signedIn()
        && getAfter(/databases/$(database)/documents/households/$(householdId))
          .data.memberIds.hasAny([request.auth.uid]);
    }

    match /users/{userId} {
      allow create: if signedIn()
        && request.auth.uid == userId
        && request.resource.data.id == userId
        && request.resource.data.email == request.auth.token.email;
      allow read: if signedIn() && request.auth.uid == userId;
      allow update: if signedIn()
        && request.auth.uid == userId
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['householdId']);
      allow delete: if false;
    }

    match /invites/{inviteCode} {
      allow get: if signedIn();
      allow list: if false;
      allow create: if signedIn()
        && request.resource.data.code == inviteCode
        && request.resource.data.createdBy == request.auth.uid
        && getAfter(
          /databases/$(database)/documents/households/$(request.resource.data.householdId)
        ).data.memberIds.hasAny([request.auth.uid]);
      allow update: if false;
      allow delete: if signedIn()
        && resource.data.createdBy == request.auth.uid;
    }

    match /households/{householdId} {
      allow create: if signedIn()
        && request.resource.data.id == householdId
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.memberIds == [request.auth.uid]
        && request.resource.data.members[request.auth.uid].email == request.auth.token.email;

      allow read: if isMember(householdId);

      allow update: if (
        isMember(householdId)
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['name', 'updatedAt'])
      ) || (
        signedIn()
        && !resource.data.memberIds.hasAny([request.auth.uid])
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['members', 'memberIds', 'updatedAt'])
        && request.resource.data.memberIds.size() == resource.data.memberIds.size() + 1
        && request.resource.data.memberIds.hasAll(resource.data.memberIds)
        && request.resource.data.memberIds.hasAny([request.auth.uid])
        && request.resource.data.members.diff(resource.data.members).affectedKeys()
          .hasOnly([request.auth.uid])
        && request.resource.data.members[request.auth.uid].email == request.auth.token.email
        && exists(
          /databases/$(database)/documents/invites/$(resource.data.inviteCode)
        )
      );

      allow delete: if false;

      match /expenses/{expenseId} {
        allow read: if isMember(householdId);
        allow create: if (isMember(householdId) || isMemberAfter(householdId))
          && request.resource.data.id == expenseId
          && request.resource.data.householdId == householdId
          && request.resource.data.createdBy == request.auth.uid
          && request.resource.data.amount is number
          && request.resource.data.amount > 0;
        allow update: if isMember(householdId)
          && resource.data.createdBy == request.auth.uid
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'amount',
            'currency',
            'date',
            'categoryId',
            'description',
            'paidByUserId',
            'paymentMethod',
            'updatedAt'
          ])
          && request.resource.data.amount is number
          && request.resource.data.amount > 0;
        allow delete: if isMember(householdId)
          && resource.data.createdBy == request.auth.uid;
      }

      match /categories/{categoryId} {
        allow read: if isMember(householdId);
        allow create: if (isMember(householdId) || isMemberAfter(householdId))
          && request.resource.data.id == categoryId
          && request.resource.data.householdId == householdId
          && request.resource.data.createdBy == request.auth.uid;
        allow update: if isMember(householdId)
          && resource.data.isDefault == false
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['name', 'color']);
        allow delete: if isMember(householdId)
          && resource.data.isDefault == false;
      }
    }
  }
}
